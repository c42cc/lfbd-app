# Required — at least one voice provider
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-key
XAI_API_KEY=your-xai-key

# Session (recommended)
SESSION_TOKEN=generate-with-uuidgen
ADMIN_TOKEN=generate-strong-random-string

# Optional
PORT=3000
DATA_DIR=./data
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview
GEMINI_LIVE_VOICE=Aoede
